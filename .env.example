# ── Required ─────────────────────────────────────────────
# The only key needed for the app to actually work.
# Google Gemini has a FREE tier. Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model for audits / research / authority / outlines. Free-tier friendly default.
# gemini-flash-latest works on the free tier where gemini-2.0-flash may be blocked (limit 0).
GEMINI_MODEL=gemini-flash-latest

# ── Optional (later phases — app runs without these) ─────
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
